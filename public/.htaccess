RewriteEngine On
RewriteBase /

# Se o arquivo ou diretorio existe, servir normalmente
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Tudo mais redireciona para index.html (SPA routing)
# Necessario para rotas client-side sobreviverem a F5 / deep links.
RewriteRule ^ index.html [QSA,L]
