# Credenciais SSH da Hostinger para o SCRIPT LOCAL de deploy
# (`./deploy-hostinger.sh` — fallback manual, uso emergencial).
#
# Deploy padrão do projeto é automático via GitHub Actions
# (push em main → .github/workflows/deploy-hostinger.yml). Esse CI usa
# CHAVE SSH (não senha) via GitHub Secrets — veja README seção "Deploy".
#
# SETUP:
#   1. cp .env.deploy.example .env.deploy
#   2. Preencha com seus dados (hPanel → Avançado → Acesso SSH)
#   3. NUNCA commite .env.deploy (já está no .gitignore)
#
# Requer: sshpass  (macOS: brew install hudochenkov/sshpass/sshpass)

HOSTINGER_HOST=xxx.xxx.xxx.xxx         # IP do painel SSH
HOSTINGER_PORT=65002                   # padrão Hostinger shared
HOSTINGER_USER=uXXXXXXXXX              # username do painel SSH
HOSTINGER_PASSWORD=                    # senha SSH (botão Change no painel)
HOSTINGER_REMOTE_ADMIN=/home/uXXXXXXXXX/domains/seu-dominio.com/public_html
HOSTINGER_REMOTE_ALUNO=/home/uXXXXXXXXX/domains/seu-dominio.com/public_html/aluno
